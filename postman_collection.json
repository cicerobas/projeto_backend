    {
      "name": "D) Pagamento Mock",
      "item": [
        {
          "name": "D1 - Processar pagamento mock (aprovado ou recusado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 - Pagamento processado pelo mock', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Resposta contém order_id e transaction_id', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.order_id).to.exist;",
                  "    pm.expect(json.transaction_id).to.be.a('string');",
                  "    pm.expect(json.status).to.be.a('string');",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "if (json.status === 'approved') {",
                  "    pm.test('Pagamento APROVADO → status approved', () => {",
                  "        pm.expect(json.status).to.eql('approved');",
                  "        console.log('Pagamento aprovado. Status:', json.status);",
                  "    });",
                  "} else {",
                  "    pm.test('Pagamento RECUSADO → status declined e payload presente', () => {",
                  "        pm.expect(json.status).to.eql('declined');",
                  "        pm.expect(json.payload).to.exist;",
                  "        console.log('Pagamento recusado. Status:', json.status, '| Payload:', json.payload);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/payments/:order_id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                ":order_id"
              ],
              "variable": [
                {
                  "key": "order_id",
                  "value": "{{order_id}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "D2 - Atualizar status do pedido após pagamento",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 - Status do pedido atualizado', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Status do pedido é delivering', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('delivering');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/:order_id/status?new_status=delivering",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                ":order_id",
                "status"
              ],
              "query": [
                {
                  "key": "new_status",
                  "value": "delivering"
                }
              ],
              "variable": [
                {
                  "key": "order_id",
                  "value": "{{order_id}}"
                }
              ]
            }
          },
          "response": []
        }
      ]
